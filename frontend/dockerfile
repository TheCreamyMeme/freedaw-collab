# ==========================================
# STAGE 1: Scaffold, Configure, and Build
# ==========================================
# Use Node.js Alpine for a lightweight build environment
FROM node:20-alpine AS builder

# Set the initial working directory
WORKDIR /app

# 1. Scaffold a fresh Vite React app non-interactively
RUN npm create vite@latest webdaw -- --template react

# Move into the newly scaffolded Vite directory
WORKDIR /app/webdaw

# 2. Install base React dependencies
RUN npm install

# 3. Install specific libraries
# (Re-adding tailwindcss-animate. Using .cjs config files below to safely prevent ESM crashes!)
RUN npm install lucide-react@0.427.0 tailwindcss@3 postcss autoprefixer tailwindcss-animate socket.io-client

# 4. Inject PostCSS Configuration dynamically (Using .cjs for CommonJS compatibility)
RUN rm -f postcss.config.js tailwind.config.js
RUN cat <<EOF > postcss.config.cjs
module.exports = {
  plugins: {
    tailwindcss: {},
    autoprefixer: {},
  },
}
EOF

# 5. Inject the Tailwind Configuration dynamically with explicit SAFELIST and Animate Plugin
RUN cat <<EOF > tailwind.config.cjs
/** @type {import("tailwindcss").Config} */
module.exports = {
  content: [
    "./index.html",
    "./src/**/*.{js,ts,jsx,tsx}",
  ],
  safelist: [
    { pattern: /bg-(emerald|blue|purple|pink|red|orange|yellow|cyan)-(400|500|600)/ },
    { pattern: /from-(emerald|blue|purple|pink|red|orange|yellow|cyan)-(400|500|600)/ },
    { pattern: /to-(emerald|blue|purple|pink|red|orange|yellow|cyan)-(400|500|600)/ },
    { pattern: /text-(emerald|blue|purple|pink|red|orange|yellow|cyan)-(400|500|600)/ },
    { pattern: /border-(emerald|blue|purple|pink|red|orange|yellow|cyan)-(400|500|600)/ },
    'animate-spin', 'animate-pulse'
  ],
  theme: {
    extend: {},
  },
  plugins: [
    require("tailwindcss-animate")
  ],
}
EOF

# 6. Inject the Base CSS
RUN cat <<EOF > src/index.css
@tailwind base;
@tailwind components;
@tailwind utilities;

body {
  margin: 0;
  overflow: hidden;
  touch-action: none;
  background-color: #0a0a0a;
  color: #d4d4d4;
}

#root {
  width: 100vw;
  height: 100vh;
}
EOF

# 6.5 HARD CACHE BUSTING: Inject meta tags directly into the index.html so browsers NEVER cache the old UI
RUN sed -i 's/<head>/<head>\n    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">\n    <meta http-equiv="Pragma" content="no-cache">\n    <meta http-equiv="Expires" content="0">/' index.html

# 7. Copy your local React file into the container
COPY DAW_WEBAPP.jsx src/App.jsx

# 8. SANITY CHECK: Force the build to crash if it detects the old ghost code!
RUN if grep -qi "coming soon" src/App.jsx; then \
      echo "======================================================="; \
      echo "❌ FATAL ERROR: DOCKER IS COPYING AN OLD FILE!"; \
      echo "Docker found the phrase 'coming soon' inside the container."; \
      echo "Check that you saved your file, are editing the right path,"; \
      echo "or have pushed your latest commits to your remote server."; \
      echo "======================================================="; \
      exit 1; \
    else \
      echo "✅ SUCCESS: Fresh code verified. No ghost text found."; \
    fi

# 9. Build the Production App
RUN npm run build


# ==========================================
# STAGE 2: Serve the app with Node 'serve'
# ==========================================
FROM node:20-alpine

# Install 'serve', a lightweight static web server perfect for SPAs
RUN npm install -g serve

# Set working directory DIRECTLY to the static files to prevent path resolution bugs
WORKDIR /app/dist

# Copy ONLY the compiled static files from Stage 1
COPY --from=builder /app/webdaw/dist .

# Generate the serve.json with Cache headers safely inside the working directory
RUN cat <<EOF > serve.json
{
  "headers": [
    {
      "source": "**/*",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
EOF

# Expose port 3000
EXPOSE 3000

# Start the server (-s handles the React SPA routing, and it natively reads serve.json from '.')
CMD ["serve", "-s", ".", "-l", "3000"]