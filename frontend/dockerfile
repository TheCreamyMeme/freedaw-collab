# ==========================================
# STAGE 1: Scaffold, Configure, and Build
# ==========================================
# Use Node.js Alpine for a lightweight build environment
FROM node:20-alpine AS builder

# Set the initial working directory
WORKDIR /app

# 1. Scaffold a fresh Vite React app non-interactively
RUN npm create vite@latest webdaw -- --template react

# Move into the newly scaffolded Vite directory
WORKDIR /app/webdaw

# 2. Install base React dependencies
RUN npm install

# 3. Install specific libraries
# (Removed tailwindcss-animate to prevent silent ESM import failures during build)
RUN npm install lucide-react tailwindcss@3 postcss autoprefixer socket.io-client

# 4. Inject PostCSS Configuration dynamically
RUN cat <<EOF > postcss.config.js
export default {
  plugins: {
    tailwindcss: {},
    autoprefixer: {},
  },
}
EOF

# 5. Inject the Tailwind Configuration dynamically with explicit SAFELIST
RUN cat <<EOF > tailwind.config.js
/** @type {import("tailwindcss").Config} */
export default {
  content: [
    "./index.html",
    "./src/**/*.{js,ts,jsx,tsx}",
  ],
  safelist: [
    { pattern: /bg-(emerald|blue|purple|pink|red|orange|yellow|cyan)-(400|500|600)/ },
    { pattern: /from-(emerald|blue|purple|pink|red|orange|yellow|cyan)-(400|500|600)/ },
    { pattern: /to-(emerald|blue|purple|pink|red|orange|yellow|cyan)-(400|500|600)/ },
    { pattern: /text-(emerald|blue|purple|pink|red|orange|yellow|cyan)-(400|500|600)/ },
    { pattern: /border-(emerald|blue|purple|pink|red|orange|yellow|cyan)-(400|500|600)/ },
    'animate-spin', 'animate-pulse'
  ],
  theme: {
    extend: {},
  },
  plugins: [],
}
EOF

# 6. Inject the Base CSS
RUN cat <<EOF > src/index.css
@tailwind base;
@tailwind components;
@tailwind utilities;

body {
  margin: 0;
  overflow: hidden;
  touch-action: none;
  background-color: #0a0a0a;
  color: #d4d4d4;
}

#root {
  width: 100vw;
  height: 100vh;
}
EOF

# 7. Create a serve.json to defeat aggressive browser caching for the SPA
RUN cat <<EOF > serve.json
{
  "headers": [
    {
      "source": "**/*.@(html|htm|css|js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
EOF

# 8. Copy your local React file into the container
COPY DAW_WEBAPP.jsx src/App.jsx

# 9. Build the Production App
RUN npm run build


# ==========================================
# STAGE 2: Serve the app with Node 'serve'
# ==========================================
FROM node:20-alpine

# Set the working directory for the production server
WORKDIR /app

# Install 'serve', a lightweight static web server perfect for SPAs
RUN npm install -g serve

# Copy ONLY the compiled static files and server config from Stage 1
COPY --from=builder /app/webdaw/dist ./dist
COPY --from=builder /app/webdaw/serve.json ./serve.json

# Expose port 3000
EXPOSE 3000

# Start the server with the cache-busting configuration
CMD ["serve", "-s", "dist", "-l", "3000", "-c", "serve.json"]